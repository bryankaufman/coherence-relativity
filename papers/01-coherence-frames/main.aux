\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Geometric entropy in coherence space~$\Sigma $. \textbf  {(a)}~The Fubini--Study arc length $s(\lambda )/s(1)$ (red dashed, frame-invariant) and von Neumann entropy $S_{\mathrm  {vN}}/\log 2$ (blue solid, frame-dependent) both run from 0 to 1 but differ structurally: $S_{\mathrm  {vN}}$ changes when the system--bath boundary is redrawn (a coherence-frame transformation), while $s(\lambda )$ does not. The shaded gap $\Delta (\lambda )$ is frame-invariant geometric information invisible to any fixed thermodynamic description (Remark~\ref {rem:frame-thermo}). \textbf  {(b)}~Geometric entropy production rate $ds/d\lambda = \sqrt  {G_{\lambda \lambda }}$: minimal at $\lambda =0$, diverging as $\lambda \to 1$. \textbf  {(c)}~Accumulated $s(\lambda )$: Fubini--Study distance and distinguishability decouple near the quantum-classical crossover ($\lambda \in [0.2,\,0.6]$).}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:geometric_entropy}{{4}{9}{Geometric entropy in coherence space~$\Sig $. \textbf {(a)}~The Fubini--Study arc length $s(\lambda )/s(1)$ (red dashed, frame-invariant) and von Neumann entropy $S_{\mathrm {vN}}/\log 2$ (blue solid, frame-dependent) both run from 0 to 1 but differ structurally: $S_{\mathrm {vN}}$ changes when the system--bath boundary is redrawn (a coherence-frame transformation), while $s(\lambda )$ does not. The shaded gap $\Delta (\lambda )$ is frame-invariant geometric information invisible to any fixed thermodynamic description (Remark~\ref {rem:frame-thermo}). \textbf {(b)}~Geometric entropy production rate $ds/d\lambda = \sqrt {\Gll }$: minimal at $\lambda =0$, diverging as $\lambda \to 1$. \textbf {(c)}~Accumulated $s(\lambda )$: Fubini--Study distance and distinguishability decouple near the quantum-classical crossover ($\lambda \in [0.2,\,0.6]$)}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Geometric distance $d_\Sigma (\lambda ) = \DOTSI \intop \ilimits@ _\lambda ^1 \!\sqrt  {G_{\lambda \lambda }}\,d\lambda '$ on coherence space (EGY parameterization, $N=10$), measuring the Fubini--Study distance from~$\lambda $ to the classical frame. In the zero-noise limit this coincides with the quasipotential~$V$ of Eq.~\eqref  {eq:action}. The finite starting value $d_\Sigma (0) \approx 1.46$ reflects the geometric accessibility of the coherent frame. The steep drop near $\lambda \to 1$ reflects the divergent metric (rigidity of classical records). The global minimum at $\lambda = 1$ (pointer basis) represents the stable classical frame.}}{9}{figure.5}\protected@file@percent }
\newlabel{fig:quasipotential}{{5}{9}{Geometric distance $d_\Sig (\lambda ) = \int _\lambda ^1 \!\sqrt {\Gll }\,d\lambda '$ on coherence space (EGY parameterization, $N=10$), measuring the Fubini--Study distance from~$\lambda $ to the classical frame. In the zero-noise limit this coincides with the quasipotential~$V$ of Eq.~\eqref {eq:action}. The finite starting value $d_\Sig (0) \approx 1.46$ reflects the geometric accessibility of the coherent frame. The steep drop near $\lambda \to 1$ reflects the divergent metric (rigidity of classical records). The global minimum at $\lambda = 1$ (pointer basis) represents the stable classical frame}{figure.5}{}}
