\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The Born rule as frame invariant: $ds^2$ in SR $\leftrightarrow $ $\mu = |c_i|^2$ in CR. \textbf  {Left (SR):} Minkowski diagram showing two frames $S, S'$; the interval $ds^2$ is identical in both. \textbf  {Right (CR):} Amplitude plane of~$\Sigma $ (Bloch sphere cross-section); the Born measure $\mu = r^2 = |c_0|^2$ is invariant under frame rotations, while individual components $|c_+|^2$ are frame-dependent.}}{9}{figure.2}\protected@file@percent }
\newlabel{fig:born_invariant}{{2}{9}{The Born rule as frame invariant: $ds^2$ in SR $\leftrightarrow $ $\mu = |c_i|^2$ in CR. \textbf {Left (SR):} Minkowski diagram showing two frames $S, S'$; the interval $ds^2$ is identical in both. \textbf {Right (CR):} Amplitude plane of~$\Sig $ (Bloch sphere cross-section); the Born measure $\mu = r^2 = |c_0|^2$ is invariant under frame rotations, while individual components $|c_+|^2$ are frame-dependent}{figure.2}{}}
