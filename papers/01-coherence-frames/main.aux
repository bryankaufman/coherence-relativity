\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Comparison of the normalized Coherence Relativity{} geometric distance $d_\Sigma (\lambda )/d_\Sigma (0)$ (solid, red) with standard QM visibility $\mathcal  {V} = \sqrt  {1-\lambda ^2}$ (dashed, blue) under the EGY parameterization $\lambda = \sqrt  {1-|\langle W_L|W_R\rangle |^2}$. The CR curve deviates from the standard QM prediction, reaching a maximum difference $\Delta \approx 0.12$ at $\lambda \approx 0.52$.}}{10}{figure.6}\protected@file@percent }
\newlabel{fig:cr_vs_standard}{{6}{10}{Comparison of the normalized \CR {} geometric distance $d_\Sig (\lambda )/d_\Sig (0)$ (solid, red) with standard QM visibility $\mathcal {V} = \sqrt {1-\lambda ^2}$ (dashed, blue) under the EGY parameterization $\lambda = \sqrt {1-|\langle W_L|W_R\rangle |^2}$. The CR curve deviates from the standard QM prediction, reaching a maximum difference $\Delta \approx 0.12$ at $\lambda \approx 0.52$}{figure.6}{}}
