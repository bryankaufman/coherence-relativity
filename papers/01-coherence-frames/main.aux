\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Geometric structure of the decoherence trajectory under the EGY parameterization $\lambda = \sqrt  {1-|\langle W_L|W_R\rangle |^2}$ (multi-mode model, $N=10$). \textbf  {(a)}~The Fubini--Study metric $G_{\lambda \lambda }= (ds/d\lambda )^2$: finite at $\lambda \to 0$ (all models: $G_{\lambda \lambda }(0)=1/2$, geometric accessibility of the coherent frame) and diverging at $\lambda \to 1$ (rigidity of classical records). \textbf  {(b)}~The inverse $d\lambda /ds = 1/\sqrt  {G_{\lambda \lambda }}$ starts at $\sqrt  {2}$ and decreases monotonically: distinguishability accumulates efficiently near the coherent endpoint and slows as classical records solidify.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:g_lambda}{{1}{4}{Geometric structure of the decoherence trajectory under the EGY parameterization $\lambda = \sqrt {1-|\langle W_L|W_R\rangle |^2}$ (multi-mode model, $N=10$). \textbf {(a)}~The Fubini--Study metric $\Gll = (ds/d\lambda )^2$: finite at $\lambda \to 0$ (all models: $\Gll (0)=1/2$, geometric accessibility of the coherent frame) and diverging at $\lambda \to 1$ (rigidity of classical records). \textbf {(b)}~The inverse $d\lambda /ds = 1/\sqrt {\Gll }$ starts at $\sqrt {2}$ and decreases monotonically: distinguishability accumulates efficiently near the coherent endpoint and slows as classical records solidify}{figure.1}{}}
