\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Geometric entropy in coherence space~$\Sigma $. \textbf  {(a)}~The Fubini--Study arc length $s(\lambda )/s(1)$ (red dashed, frame-invariant) and von Neumann entropy $S_{\mathrm  {vN}}/\log 2$ (blue solid, frame-dependent) both run from 0 to 1 but differ structurally: $S_{\mathrm  {vN}}$ changes when the system--bath boundary is redrawn (a coherence-frame transformation), while $s(\lambda )$ does not. The shaded gap $\Delta (\lambda )$ is frame-invariant geometric information invisible to any fixed thermodynamic description (Remark~\ref {rem:frame-thermo}). \textbf  {(b)}~Geometric entropy production rate $ds/d\lambda = \sqrt  {G_{\lambda \lambda }}$: minimal at $\lambda =0$, diverging as $\lambda \to 1$. \textbf  {(c)}~Accumulated $s(\lambda )$: Fubini--Study distance and distinguishability decouple near the quantum-classical crossover ($\lambda \in [0.2,\,0.6]$).}}{13}{figure.4}\protected@file@percent }
\newlabel{fig:geometric_entropy}{{4}{13}{Geometric entropy in coherence space~$\Sig $. \textbf {(a)}~The Fubini--Study arc length $s(\lambda )/s(1)$ (red dashed, frame-invariant) and von Neumann entropy $S_{\mathrm {vN}}/\log 2$ (blue solid, frame-dependent) both run from 0 to 1 but differ structurally: $S_{\mathrm {vN}}$ changes when the system--bath boundary is redrawn (a coherence-frame transformation), while $s(\lambda )$ does not. The shaded gap $\Delta (\lambda )$ is frame-invariant geometric information invisible to any fixed thermodynamic description (Remark~\ref {rem:frame-thermo}). \textbf {(b)}~Geometric entropy production rate $ds/d\lambda = \sqrt {\Gll }$: minimal at $\lambda =0$, diverging as $\lambda \to 1$. \textbf {(c)}~Accumulated $s(\lambda )$: Fubini--Study distance and distinguishability decouple near the quantum-classical crossover ($\lambda \in [0.2,\,0.6]$)}{figure.4}{}}
\newlabel{rem:frame-thermo}{{7}{13}{Frame-dependence of thermodynamic quantities}{remark.7}{}}
